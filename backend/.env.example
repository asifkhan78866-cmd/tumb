# ============================================================================
# Backend environment configuration — copy to `.env` and fill in.
#   cp backend/.env.example backend/.env
# ============================================================================

# --- Kaggle API credentials (required for automatic dataset download) --------
# Get these from https://www.kaggle.com/settings  ->  "Create New API Token"
# (downloads a kaggle.json containing "username" and "key").
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- Dataset slugs (override only if you want different Kaggle datasets) ------
# KAGGLE_CLASSIFICATION=masoudnickparvar/brain-tumor-mri-dataset
# KAGGLE_CLASSIFICATION_FALLBACK=navoneel/brain-mri-images-for-brain-tumor-detection
# KAGGLE_SEGMENTATION=awsaf49/brats2020-training-data

# --- API / CORS --------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Training hyper-parameters (optional overrides) --------------------------
SEG_EPOCHS=50
CLS_EPOCHS=40
BATCH_SIZE=16
LEARNING_RATE=0.001
NUM_WORKERS=2
EARLY_STOP_PATIENCE=10
